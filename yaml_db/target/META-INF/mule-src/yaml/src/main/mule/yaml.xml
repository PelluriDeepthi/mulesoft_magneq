			<db:sql ><![CDATA[select * from accounts]]></db:sql>
		</db:select>
		<ee:transform doc:name="Transform Message" doc:id="d72708de-380d-4134-befd-aee113dae233" >
			<ee:message >
				<ee:set-payload ><![CDATA[%dw 2.0
output application/json
---
payload]]></ee:set-payload>
			</ee:message>
		</ee:transform>
		<logger level="INFO" doc:name="Logger" doc:id="dd7d34c3-596b-43fb-b01f-8cdba2b6531e" />
	</flow>
</mule>
