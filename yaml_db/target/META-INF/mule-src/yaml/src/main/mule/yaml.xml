	<http:listener-config name="HTTP_Listener_config" doc:name="HTTP Listener config" doc:id="ee730377-6460-4c36-aec8-0745d660a302" >
		<http:listener-connection host="localhost" port="8081" />
	</http:listener-config>
	<db:config name="Database_Config" doc:name="Database Config" doc:id="0910ec1c-045a-4788-bd7b-5e659027bf8b" >
		<db:my-sql-connection host="${database.host}" port="${database.port}" user="${database.username}" password="${secure::database.password}" database="${database.dbname}" />
	</db:config>
	<configuration-properties doc:name="Configuration properties" doc:id="8d663698-75f6-426f-9880-b70c17812f64" file="external\external-dev.yaml" />
	<secure-properties:config name="Secure_Properties_Config" doc:name="Secure Properties Config" doc:id="61d830d2-8c46-4e6c-9ad7-a4485e988c31" file="external\external-dev-secure.yaml" key="a1b2c3d4e5f6-dev" />
	<flow name="yamlFlow" doc:id="2de05ab4-2a0e-496a-9808-ecf3a02b97c8" >
		<http:listener doc:name="Listener" doc:id="ee03ded3-3b62-4453-a38b-59172fb8659c" config-ref="HTTP_Listener_config" path="/datayaml"/>
		<logger level="INFO" doc:name="Logger" doc:id="9ab69797-62ce-47e9-ad6c-361e46e54f0e" />
